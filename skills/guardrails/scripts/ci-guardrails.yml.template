  #   runs-on: ubuntu-latest
  #   steps:
  #     - run: psql "$DB_URL" -f checks/rls_disabled_tables.sql -v ON_ERROR_STOP=1
  #     - run: psql "$DB_URL" -f checks/tenant_column_invariant.sql -v ON_ERROR_STOP=1
